@startuml
title Validate Command - Blockchain Validation Sequence
autoactivate on

actor User
participant "app:Crypto1010" as App
participant "parser:Parser" as Parser
participant "chain:Blockchain" as Chain
participant "block:Block" as Block

User -> App: validate
App -> Parser: parse("validate")
create Validate
Parser -> Validate: <<create>> ValidateCommand()
Parser --> App: validateCmd
App -> Validate: execute(chain, in)
Validate -> Chain: validate()

loop each block i from 0..n-1
  Chain -> Block: getIndex()
  Block --> Chain: index
  Chain -> Block: computeCurrentHash()
  Block --> Chain: computedHash
  Chain -> Block: getCurrentHash()
  Block --> Chain: storedHash
  Chain -> Block: hasValidTransactionData()
  Block --> Chain: isValid

  alt i == 0 (genesis)
    Chain -> Block: getPreviousHash()
    Block --> Chain: previousHash
    Chain -> Chain: verify genesis marker
  else i > 0
    Chain -> Chain: verify previous hash linkage
    Chain -> Chain: parse tx and validate balances
  end
end

Chain --> Validate: ValidationResult
Validate -> User: print validation result
Validate --> App: return

@enduml
