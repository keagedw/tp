@startuml
title Send Command - Block Append and Hash Chaining

actor User
participant "Crypto1010" as App
participant "Parser" as Parser
participant "SendCommand" as Send
participant "TransactionRecordingService" as Service
participant "WalletManager" as WM
participant "Blockchain" as Chain
participant "Block(last)" as LastBlock
participant "Block(new)" as NewBlock
database "WalletStorage" as WS
database "BlockchainStorage" as BS

User -> App: send w/bob to/0x... amt/2 fee/0.001
App -> Parser: parse(rawInput)
Parser --> App: SendCommand
App -> Send: execute(...)
Send -> WM: hasWallet("bob")
WM --> Send: true
Send -> Service: recordTransfer(request, blockchain)

Service -> WM: findWallet("bob")
WM --> Service: Wallet bob
Service -> Chain: getPreciseBalance("bob")
Chain --> Service: currentBalance
Service -> Chain: addTransactions([txTransfer, txFee])

Chain -> LastBlock: getIndex(), getCurrentHash()
LastBlock --> Chain: index, hash
Chain -> NewBlock: new Block(index+1, now, previousHash, txs)
NewBlock -> NewBlock: compute SHA-256 currentHash
NewBlock --> Chain: block
Chain -> Chain: append block to blocks list

Service --> Send: success
Send --> App: print transfer summary
App -> BS: save(blockchain)
App -> WS: save(walletManager)
App --> User: output

@enduml
