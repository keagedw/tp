@startuml
title Send Command - Block Append and Hash Chaining
autoactivate on

actor User
participant "app:Crypto1010" as App
participant "parser:Parser" as Parser
participant "sendCmd:SendCommand" as Send
participant "txService:TransactionRecordingService" as Service
participant "walletManager:WalletManager" as WM
participant "chain:Blockchain" as Chain
participant "lastBlock:Block" as LastBlock
participant "walletStorage:WalletStorage" as WS
participant "blockchainStorage:BlockchainStorage" as BS

User -> App: send w/bob to/0x... amt/2 fee/0.001
App -> Parser: parse(rawInput)
create Send
Parser -> Send: <<create>> SendCommand(arguments, walletManager)
Parser --> App: sendCmd
App -> Send: execute(chain, in)

Send -> WM: hasWallet("bob")
WM --> Send: exists?
alt wallet not found
  Send --> App: throw Crypto1010Exception
  App --> User: print error
else wallet found
  Send -> Service: recordTransfer(request, chain)
  Service -> WM: findWallet("bob")
  WM --> Service: senderWallet
  Service -> Chain: getPreciseBalance("bob")
  Chain --> Service: senderBalance
  Service -> Chain: addTransactions([transferTx, feeTx?])

  Chain -> LastBlock: getIndex()
  LastBlock --> Chain: lastIndex
  Chain -> LastBlock: getCurrentHash()
  LastBlock --> Chain: previousHash

  create "newBlock:Block" as NewBlock
  Chain -> NewBlock: new Block(lastIndex+1, now, previousHash, txs)
  NewBlock --> Chain: createdBlock
  Chain -> Chain: append createdBlock

  Service --> Send: success
  Send -> User: print transfer summary
  Send --> App: return
  App -> BS: save(chain)
  App -> WS: save(walletManager)
end

@enduml
